# ============================================================
# YOZGO - Environment Variables Template
# Nusxa oling:  cp .env.example .env   va qiymatlarni to'ldiring
# ============================================================

# ---------- MAJBURIY (server ishga tushishi uchun shart) ----------
# PostgreSQL ulanish satri. Server usiz ishga tushmaydi (server/db.ts).
DATABASE_URL=postgres://user:password@localhost:5432/yozgo

# Session imzolash kaliti. auth.ts usiz serverni to'xtatadi.
SESSION_SECRET=change-me-to-a-long-random-string

# --- PostgreSQL SSL (OPT-IN) ---
# Self-hosted Postgres (Coolify internal network) ODATDA SSL'siz — bu holda ikkalasini
# ham BO'SH qoldiring (SSL majburlanmaydi).
# DB_SSL=true  -> SSL yoqiladi (managed DB uchun; yoki DATABASE_URL'ga ?sslmode=require qo'shing).
DB_SSL=
# DB_CA_CERT (PEM matni) -> qat'iy TLS tekshiruvi (rejectUnauthorized: true). Eng xavfsiz.
DB_CA_CERT=

# ---------- IXTIYORIY ----------
# Ishlash rejimi: development | production | test
NODE_ENV=development
# Server porti (standart: 5000)
PORT=5000
# Frontend uchun backend manzili (Google OAuth callback uchun)
BACKEND_URL=

# --- Rejalashtirilgan vazifalar (cron: streak eslatma, haftalik rollover + liga reset) ---
# Cron FAQAT NODE_ENV=production VA RUN_CRON=true bo'lganda ishga tushadi. Ko'p instance'li
# deploy'da faqat BITTA instance'ga true qo'ying (dublikat xabar/reset bo'lmasin).
RUN_CRON=false

# Admin huquqlari beriladigan emaillar (vergul bilan)
ADMIN_EMAILS=

# --- Telegram integratsiyasi (ixtiyoriy) ---
TELEGRAM_BOT_TOKEN=
USER_BOT_TOKEN=
ADMIN_BOT_TOKEN=
ADMIN_CHAT_ID=
ADMIN_TELEGRAM_ID=

# --- Admin bot <-> server autentifikatsiyasi ---
# Tashqi admin-bot server admin API'siga kirishda yuboradigan sir (x-bot-secret header).
# routes.ts adminGuard/adminAuth shuni tekshiradi. Uzun tasodifiy satr bo'lsin.
BOT_SECRET=
# BOT_SECRET uchun zaxira nom (agar BOT_SECRET bo'sh bo'lsa ishlatiladi).
ADMIN_API_TOKEN=

# --- Google OAuth (ixtiyoriy) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ID=
GOOGLE_SECRET=

# --- Email / SMTP (parol tiklash, OTP uchun) ---
SMTP_USER=
SMTP_PASS=

# --- Xatoliklarni kuzatish (ixtiyoriy) ---
SENTRY_DSN=

# --- Frontend build vaqtidagi API manzili (ixtiyoriy) ---
# userBot mini-app URL (server tomonda ishlatiladi; '/api' olib tashlanadi).
VITE_API_BASE_URL=
# Client build API bazasi (import.meta.env.VITE_API_URL). Bo'sh bo'lsa nisbiy '/api'.
VITE_API_URL=

# ============================================================
# ESLATMA: quyidagilar kodda HOZIRCHA ISHLATILMAYDI (qo'shish shart emas):
#   REDIS_URL                   -> Redis yo'q; session PostgreSQL'da saqlanadi.
#   RESEND_API_KEY / BREVO_...  -> Email nodemailer + SMTP (SMTP_USER/SMTP_PASS) orqali.
#   CLIENT_ORIGIN               -> CORS origin ro'yxati server/index.ts ichida qat'iy.
# ============================================================
