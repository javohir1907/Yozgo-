# ============================================================
# YOZGO - Environment Variables Template
# Nusxa oling:  cp .env.example .env   va qiymatlarni to'ldiring
# ============================================================

# ---------- MAJBURIY (server ishga tushishi uchun shart) ----------
# PostgreSQL ulanish satri. Server usiz ishga tushmaydi (server/db.ts).
DATABASE_URL=postgres://user:password@localhost:5432/yozgo

# Session imzolash kaliti. auth.ts usiz serverni to'xtatadi.
SESSION_SECRET=change-me-to-a-long-random-string

# ---------- IXTIYORIY ----------
# Ishlash rejimi: development | production | test
NODE_ENV=development
# Server porti (standart: 5000)
PORT=5000
# Frontend uchun backend manzili (Google OAuth callback uchun)
BACKEND_URL=

# Admin huquqlari beriladigan emaillar (vergul bilan)
ADMIN_EMAILS=

# --- Telegram integratsiyasi (ixtiyoriy) ---
TELEGRAM_BOT_TOKEN=
USER_BOT_TOKEN=
ADMIN_BOT_TOKEN=
ADMIN_CHAT_ID=
ADMIN_TELEGRAM_ID=

# --- Admin bot <-> server autentifikatsiyasi ---
# Tashqi admin-bot server admin API'siga kirishda yuboradigan sir (x-bot-secret header).
# routes.ts adminGuard/adminAuth shuni tekshiradi. Uzun tasodifiy satr bo'lsin.
BOT_SECRET=
# BOT_SECRET uchun zaxira nom (agar BOT_SECRET bo'sh bo'lsa ishlatiladi).
ADMIN_API_TOKEN=

# --- Google OAuth (ixtiyoriy) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ID=
GOOGLE_SECRET=

# --- Email / SMTP (parol tiklash, OTP uchun) ---
SMTP_USER=
SMTP_PASS=

# --- Xatoliklarni kuzatish (ixtiyoriy) ---
SENTRY_DSN=

# --- Frontend build vaqtidagi API manzili (ixtiyoriy) ---
VITE_API_BASE_URL=
